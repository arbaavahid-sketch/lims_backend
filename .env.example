# این فایل را کپی کنید به نام .env و مقادیر را پر کنید
# cp .env.example .env

# ---------- توسعهٔ محلی (بدون Docker) ----------
# اگر DATABASE_URL ندهید، از SQLite محلی (lims_dev.db) استفاده می‌شود — نیازی به نصب چیزی نیست.
# DATABASE_URL=sqlite:///./lims_dev.db

# ---------- استقرار با docker-compose ----------
# رمز دیتابیس PostgreSQL (الزامی برای docker compose)
POSTGRES_PASSWORD=a-strong-db-password
# POSTGRES_USER=lims
# POSTGRES_DB=lims
# پورت وب‌سایت (پیش‌فرض 80)
# HTTP_PORT=80

# کلید امضای توکن JWT — حتماً یک رشتهٔ تصادفی و امن بگذارید (در هر دو حالت الزامی)
# ساخت کلید امن:  python -c "import secrets; print(secrets.token_hex(32))"
LIMS_SECRET_KEY=change-this-secret-in-production
