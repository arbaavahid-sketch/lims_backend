# این فایل را کپی کنید به نام .env و مقادیر را پر کنید
# cp .env.example .env

# آدرس اتصال به دیتابیس PostgreSQL
# فرمت: postgresql://کاربر:رمز@هاست:پورت/نام_دیتابیس
DATABASE_URL=postgresql://lims_user:lims_pass@localhost:5432/lims_db

# کلید امضای توکن JWT — حتماً یک رشته تصادفی و امن بگذارید
# برای ساخت یک کلید امن:  python -c "import secrets; print(secrets.token_hex(32))"
LIMS_SECRET_KEY=change-this-secret-in-production
