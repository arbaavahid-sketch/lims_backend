<tal:t define="collection python:view.collection;
               accredited_symbol string:★;
               outofrange_symbol string:△;
               global footnotes python:[];
               report_options python:options.get('report_options', {});
               show_conditions python:bool(report_options.get('show_conditions', True));
               english_report python:view.is_report_english();"
       i18n:domain="senaite.impress">

  <tal:model repeat="model collection">

    <div class="row section-results no-gutters">
      <div class="w-100">
        <h1 i18n:translate="">Results for <span i18n:name="id" tal:replace="model/getId"/></h1>

        <tal:poc define="analyses_by_poc python:view.get_analyses_by_poc(model);"
                 tal:repeat="poc analyses_by_poc">

          <tal:categories_in_poc define="categories_by_poc python:view.get_categories_by_poc(model)"
                                 repeat="category python:view.sort_items(categories_by_poc.get(poc))">

            <table class="table table-sm table-condensed">
              <colgroup tal:condition="not:english_report">
                <col class="specs-col" style="width: 16%;">
                <col class="unit-col" style="width: 14%;">
                <col class="result-col" style="width: 14%;">
                <col class="method-col" style="width: 20%;">
                <col class="analysis-col" style="width: 36%;">
              </colgroup>
              <colgroup tal:condition="english_report">
                <col class="analysis-col" style="width: 36%;">
                <col class="method-col" style="width: 20%;">
                <col class="result-col" style="width: 14%;">
                <col class="unit-col" style="width: 14%;">
                <col class="specs-col" style="width: 16%;">
              </colgroup>
              <thead>
                <tr>
                  <th class="category-header" colspan="5">
                    <span tal:define="category_title category/Title"
                          tal:content="python:view.translate_report_text(category_title)">Category</span>
                  </th>
                </tr>
                <tr class="small">
                  <tal:fa condition="not:english_report">
                    <th class="specs" i18n:translate="">Range</th>
                    <th class="unit" i18n:translate="">Unit</th>
                    <th class="result" i18n:translate="">Result</th>
                    <th class="method" i18n:translate="">Test Method</th>
                    <th class="analysis" i18n:translate="">Analysis</th>
                  </tal:fa>
                  <tal:en condition="english_report">
                    <th class="analysis" i18n:translate="">Analysis</th>
                    <th class="method" i18n:translate="">Test Method</th>
                    <th class="result" i18n:translate="">Result</th>
                    <th class="unit" i18n:translate="">Unit</th>
                    <th class="specs" i18n:translate="">Range</th>
                  </tal:en>
                </tr>
              </thead>

              <tbody>
                <tal:analyses tal:repeat="analysis python:view.get_analyses_by(model, poc=poc, category=category)">
                  <tr>
                    <tal:en condition="english_report">
                      <td class="analysis">
                        <span class="text-success accredited-symbol"
                              tal:content="accredited_symbol"
                              tal:condition="analysis/Accredited">
                        </span>
                        <span tal:condition="not:analysis/ScientificName">
                          <span class="font-weight-normal"
                                tal:content="python:view.get_analysis_title(analysis)">Analysis</span>
                        </span>
                        <span tal:condition="analysis/ScientificName">
                          <span class="font-italic"
                                tal:content="python:view.get_analysis_title(analysis)">Scientific analysis</span>
                        </span>

                        <tal:analysis_footnotes define="analysis_footnotes python:[];">

                          <tal:analysis_conditions
                            define="conditions python:view.get_analysis_conditions(analysis)"
                            condition="show_conditions">
                            <tal:x define="dummy python:analysis_footnotes.extend(conditions)">
                          </tal:analysis_conditions>

                          <tal:interim_fields
                              define="interims python:view.get_result_variables(analysis);
                                      dummy python:analysis_footnotes.extend(interims)">
                          </tal:interim_fields>

                          <tal:x condition="analysis_footnotes">
                            <sup tal:define="dummy python:footnotes.append(analysis_footnotes)"
                                 tal:content="python: len(footnotes)"/>
                          </tal:x>

                        </tal:analysis_footnotes>
                      </td>
                      <td class="method">
                        <span tal:content="python:view.get_analysis_method_title(analysis)">ASTM D1319</span>
                      </td>
                      <td class="result"
                          tal:define="out_of_range python:model.is_out_of_range(analysis);
                                      results_range python:analysis.getResultsRange();
                                      comment python:results_range.get('rangecomment');">
                        <span tal:content="structure python:model.get_formatted_result(analysis)"
                              tal:attributes="class python:'text-danger font-weight-bold' if out_of_range else ''">23</span>
                        <span tal:condition="out_of_range"
                              class="outofrange text-danger"
                              tal:content="outofrange_symbol"/>
                        <span class="text-danger small"
                              tal:condition="python:out_of_range and comment"
                              tal:content="comment"/>
                      </td>
                      <td class="unit text-muted font-italic">
                        <span class="units" tal:content="structure python:model.get_formatted_unit(analysis)">mg/kg</span>
                      </td>
                      <td class="specs">
                        <span tal:content="python:model.get_formatted_specs(analysis)">(RT)</span>
                      </td>
                    </tal:en>

                    <tal:fa condition="not:english_report">
                      <td class="specs">
                        <span tal:content="python:model.get_formatted_specs(analysis)">(RT)</span>
                      </td>

                      <td class="unit text-muted font-italic">
                        <span class="units" tal:content="structure python:model.get_formatted_unit(analysis)">mg/kg</span>
                      </td>

                      <td class="result"
                          tal:define="out_of_range python:model.is_out_of_range(analysis);
                                      results_range python:analysis.getResultsRange();
                                      comment python:results_range.get('rangecomment');">
                        <span tal:content="structure python:model.get_formatted_result(analysis)"
                              tal:attributes="class python:'text-danger font-weight-bold' if out_of_range else ''">23</span>
                        <span tal:condition="out_of_range"
                              class="outofrange text-danger"
                              tal:content="outofrange_symbol"/>
                        <span class="text-danger small"
                              tal:condition="python:out_of_range and comment"
                              tal:content="comment"/>
                      </td>

                      <td class="method">
                        <span tal:content="python:view.get_analysis_method_title(analysis)">ASTM D1319</span>
                      </td>

                      <td class="analysis">
                        <span class="text-success accredited-symbol"
                              tal:content="accredited_symbol"
                              tal:condition="analysis/Accredited">
                        </span>
                        <span tal:condition="not:analysis/ScientificName">
                          <span class="font-weight-normal"
                                tal:content="python:view.get_analysis_title(analysis)">Analysis</span>
                        </span>
                        <span tal:condition="analysis/ScientificName">
                          <span class="font-italic"
                                tal:content="python:view.get_analysis_title(analysis)">Scientific analysis</span>
                        </span>

                        <tal:analysis_footnotes define="analysis_footnotes python:[];">

                          <tal:analysis_conditions
                            define="conditions python:view.get_analysis_conditions(analysis)"
                            condition="show_conditions">
                            <tal:x define="dummy python:analysis_footnotes.extend(conditions)">
                          </tal:analysis_conditions>

                          <tal:interim_fields
                              define="interims python:view.get_result_variables(analysis);
                                      dummy python:analysis_footnotes.extend(interims)">
                          </tal:interim_fields>

                          <tal:x condition="analysis_footnotes">
                            <sup tal:define="dummy python:footnotes.append(analysis_footnotes)"
                                 tal:content="python: len(footnotes)"/>
                          </tal:x>

                        </tal:analysis_footnotes>
                      </td>
                    </tal:fa>
                  </tr>
                </tal:analyses>
              </tbody>

              <tfoot tal:define="category_comments python:category.Comments">
                <tr tal:condition="category_comments">
                  <td colspan="5">
                    <div class="category_comments"
                         tal:content="category_comments">
                      Category Comments
                    </div>
                  </td>
                </tr>
                <tr tal:condition="footnotes">
                  <td colspan="5">
                    <ul class="list-unstyled footnotes">
                      <li tal:repeat="analysis_footnotes footnotes" class="mt-2">
                        <sup tal:content="repeat/analysis_footnotes/number"/>
                        <tal:footnotes repeat="footnote analysis_footnotes">
                          <tal:footnote>
                            <br tal:condition="repeat/footnote/index"/>
                            <span tal:condition="repeat/footnote/index" class="pl-2"/>
                            <span tal:content="footnote/title"/>:
                            <span tal:content="footnote/formatted_value"/>
                            <span tal:content="footnote/formatted_unit|nothing"/>
                          </tal:footnote>
                        </tal:footnotes>
                      </li>
                    </ul>
                  </td>
                </tr>
              </tfoot>
            </table>
          </tal:categories_in_poc>

        </tal:poc>
      </div>
    </div>
  </tal:model>
</tal:t>
